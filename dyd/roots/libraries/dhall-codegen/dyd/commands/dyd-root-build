#!/usr/bin/env bash

#
# abort on error
# https://sipb.mit.edu/doc/safe-shell/
set -euf -o pipefail

_set_logging () {
    case $DYD_LOG_LEVEL in
        # turn on shell script debug logs for trace and debug log levels
        'debug' | 'trace' ) set -x ;;
        * ) ;;
    esac
}

_set_globals () {
    SRC_PACKAGE=$DYD_STEM
    SRC_ASSETS=$SRC_PACKAGE/dyd/assets

    DEST_PACKAGE=$DYD_BUILD
    DEST_ASSETS=$DEST_PACKAGE/dyd/assets
    DEST_COMMANDS=$DEST_PACKAGE/dyd/commands
    DEST_DEPENDENCIES=$DEST_PACKAGE/dyd/dependencies
    DEST_MAIN=$DEST_COMMANDS/dyd-stem-run
    DEST_TRAITS=$DEST_PACKAGE/dyd/traits

    OUTPUT=$(cat "$SRC_PACKAGE/dyd/traits/output")
    VERSION=$(cat "$SRC_PACKAGE/dyd/traits/version")
}

_prepare_dest () {
    mkdir -p "$DEST_ASSETS" "$DEST_COMMANDS" "$DEST_DEPENDENCIES" "$DEST_TRAITS"
    printf '%s' dhall-codegen > "$DEST_TRAITS/name"
    printf '%s' "$OUTPUT" > "$DEST_TRAITS/output"
    printf '%s' "$VERSION" > "$DEST_TRAITS/version"
}

_build_package_output () {

    # copy source assets to dest
    cp -r "$SRC_ASSETS/src/." "$DEST_ASSETS"
    chmod -R +w "$DEST_ASSETS/"

    # run dhall format on source code
    # run dhall formatting on all source files to check
    # for assertion errors
    cd "$DEST_ASSETS" && dhall format $(find ./ -type f -name '*.dhall')

}

_build_archive_output () {
    ARCHIVE_DIR=dhall-codegen-$VERSION
    ARCHIVE_NAME=$ARCHIVE_DIR.tar.gz
    STAGING_DIR=$DEST_PACKAGE/archive-staging

    mkdir -p "$STAGING_DIR/$ARCHIVE_DIR"
    cp -r "$SRC_ASSETS/src/." "$STAGING_DIR/$ARCHIVE_DIR"
    chmod -R +w "$STAGING_DIR"

    cd "$STAGING_DIR" && tar -czf "$DEST_ASSETS/$ARCHIVE_NAME" "$ARCHIVE_DIR"
    rm -rf "$STAGING_DIR"

    printf '%s' "$ARCHIVE_NAME" > "$DEST_TRAITS/archive-name"
}

_build_package () {
    _prepare_dest

    case "$OUTPUT" in
        archive) _build_archive_output ;;
        package) _build_package_output ;;
        *)
            echo "unsupported dhall-codegen output variant: $OUTPUT" >&2
            exit 1
            ;;
    esac
}

_set_logging
_set_globals
_build_package
